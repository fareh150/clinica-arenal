---
const currentYear = new Date().getFullYear();

const treatmentLinks = [
  { href: '/tratamientos/fisioterapia-deportiva', label: 'Fisioterapia Deportiva' },
  { href: '/tratamientos/osteopatia', label: 'Osteopatía' },
  { href: '/tratamientos/puncion-seca', label: 'Punción Seca' },
  { href: '/tratamientos/pilates', label: 'Pilates' },
  { href: '/tratamientos/columna-vertebral', label: 'Tratamientos de Columna' },
  { href: '/tratamientos/fisioterapia-embarazo', label: 'Fisioterapia Embarazo' },
];

const companyLinks = [
  { href: '/quienes-somos', label: 'Quiénes Somos' },
  { href: '/instalaciones', label: 'Instalaciones' },
  { href: '/blog', label: 'Blog' },
  { href: '/contacto', label: 'Contacto' },
  { href: '/politica-privacidad', label: 'Política de Privacidad' },
  { href: '/aviso-legal', label: 'Aviso Legal' },
];
---

<footer class="bg-dark text-white">
  <div class="container-content py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">

      <!-- Columna 1: Marca -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <img
            src="/images/logo-clinica-arenal.jpg"
            alt="Clínica Arenal"
            width="40"
            height="40"
            class="h-10 w-auto rounded-lg"
          />
          <span class="text-lg font-bold">Clínica Arenal</span>
        </div>
        <p class="text-gray-400 text-sm leading-relaxed mb-4">
          Fisioterapeutas y osteópatas con amplia experiencia. Trato cercano y profesional para
          mejorar tu salud y bienestar en Carabanchel, Madrid.
        </p>
        <!-- Rating badge -->
        <div class="inline-flex items-center gap-2 bg-white/10 rounded-lg px-3 py-2">
          <span class="text-yellow-400 text-sm font-bold">★ 5.0</span>
          <span class="text-gray-300 text-xs">31 reseñas en Google</span>
        </div>
        <!-- Social -->
        <div class="mt-4">
          <a
            href="https://www.facebook.com/p/Cl%C3%ADnica-Arenal-100063808891649/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-gray-400 hover:text-white text-sm transition-colors"
            aria-label="Facebook de Clínica Arenal"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
            Facebook
          </a>
        </div>
      </div>

      <!-- Columna 2: Tratamientos -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-300 mb-4">
          Tratamientos
        </h3>
        <ul class="space-y-2" role="list">
          {treatmentLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-gray-400 hover:text-white text-sm transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
          <li>
            <a href="/tratamientos" class="text-primary-light hover:text-white text-sm font-medium transition-colors">
              Ver todos →
            </a>
          </li>
        </ul>
      </div>

      <!-- Columna 3: Empresa -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-300 mb-4">
          Empresa
        </h3>
        <ul class="space-y-2" role="list">
          {companyLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-gray-400 hover:text-white text-sm transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Columna 4: Contacto -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-300 mb-4">
          Contacto
        </h3>
        <address class="not-italic space-y-3">
          <div class="flex gap-2 text-gray-400 text-sm">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-primary-light" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>C/ Alba de Tormes, 35<br />Carabanchel, 28025 Madrid</span>
          </div>
          <div class="flex gap-2 items-center">
            <svg class="w-4 h-4 flex-shrink-0 text-primary-light" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+34912507727" class="text-gray-400 hover:text-white text-sm transition-colors">
              912 50 77 27
            </a>
          </div>
          <div class="flex gap-2 items-center">
            <svg class="w-4 h-4 flex-shrink-0 text-primary-light" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            <a href="https://wa.me/34601335732" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white text-sm transition-colors">
              601 335 732 (WhatsApp)
            </a>
          </div>
          <div class="flex gap-2 items-center">
            <svg class="w-4 h-4 flex-shrink-0 text-primary-light" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:clinica@fisioarenal.com" class="text-gray-400 hover:text-white text-sm transition-colors">
              clinica@fisioarenal.com
            </a>
          </div>
        </address>

        <!-- Horario -->
        <div class="mt-4 pt-4 border-t border-white/10">
          <p class="text-gray-300 text-xs font-medium mb-1">Horario:</p>
          <p class="text-gray-400 text-xs">Lunes a Viernes: 10:00 – 20:00</p>
          <p class="text-gray-500 text-xs">Cerrado sábados y domingos</p>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-gray-500">
      <p>© {currentYear} Clínica Arenal. Fisioterapia y Osteopatía. Todos los derechos reservados.</p>
      <div class="flex gap-4">
        <a href="/politica-privacidad" class="hover:text-gray-300 transition-colors">Política de Privacidad</a>
        <a href="/aviso-legal" class="hover:text-gray-300 transition-colors">Aviso Legal</a>
      </div>
    </div>
  </div>
</footer>
