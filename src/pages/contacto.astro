---
import BaseLayout from '../layouts/BaseLayout.astro';
import { services } from '../data/services';
---

<BaseLayout
  title="Contacto y Cita Previa | Clínica Arenal Madrid"
  description="Pide cita en Clínica Arenal. C/ Alba de Tormes 35, Carabanchel. Tel: 912 50 77 27. Metro San Francisco (L11) y Eugenia de Montijo (L5)."
  canonical="https://www.fisioarenal.com/contacto"
>

  <!-- HERO -->
  <section class="bg-gray-light section-padding">
    <div class="container-content text-center">
      <span class="text-primary font-semibold text-sm uppercase tracking-wider">Estamos aquí para ayudarte</span>
      <h1 class="text-4xl md:text-5xl font-bold text-dark mt-2 mb-4">
        Contacto y Cita Previa
      </h1>
      <p class="text-gray-secondary text-lg max-w-2xl mx-auto">
        Ponte en contacto con nosotros para pedir cita o resolver cualquier duda.
        Te atendemos de lunes a viernes.
      </p>
    </div>
  </section>

  <!-- CONTENIDO -->
  <section class="section-padding">
    <div class="container-content">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

        <!-- FORMULARIO -->
        <div>
          <h2 class="text-2xl font-bold text-dark mb-6">Escríbenos</h2>

          <form id="contact-form" class="space-y-5" novalidate>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-sm font-medium text-dark mb-1.5">
                  Nombre <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  autocomplete="given-name"
                  placeholder="Tu nombre"
                  class="w-full px-4 py-3 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-dark mb-1.5">
                  Email <span class="text-red-500">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  autocomplete="email"
                  placeholder="tu@email.com"
                  class="w-full px-4 py-3 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
                />
              </div>
            </div>

            <div>
              <label for="phone" class="block text-sm font-medium text-dark mb-1.5">
                Teléfono
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                autocomplete="tel"
                placeholder="6XX XXX XXX"
                class="w-full px-4 py-3 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
              />
            </div>

            <div>
              <label for="treatment" class="block text-sm font-medium text-dark mb-1.5">
                Tratamiento de interés
              </label>
              <select
                id="treatment"
                name="treatment"
                class="w-full px-4 py-3 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all bg-white"
              >
                <option value="">Selecciona un tratamiento</option>
                {services.map((service) => (
                  <option value={service.slug}>{service.title}</option>
                ))}
                <option value="otro">Otro / No sé</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-dark mb-1.5">
                Mensaje <span class="text-red-500">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="4"
                placeholder="Cuéntanos tu caso o la consulta que tienes..."
                class="w-full px-4 py-3 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all resize-none"
              ></textarea>
            </div>

            <!-- Estado del envío -->
            <div id="form-status" class="hidden">
              <div id="form-success" class="hidden bg-green-50 border border-green-200 text-green-800 rounded-lg px-4 py-3 text-sm flex items-center gap-2">
                <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                ¡Mensaje enviado! Te contactaremos lo antes posible.
              </div>
              <div id="form-error" class="hidden bg-red-50 border border-red-200 text-red-800 rounded-lg px-4 py-3 text-sm flex items-center gap-2">
                <svg class="w-5 h-5 text-red-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
                Ha ocurrido un error. Por favor, llámanos al 912 50 77 27.
              </div>
            </div>

            <button
              type="submit"
              id="submit-btn"
              class="btn-primary w-full justify-center text-base py-3.5"
            >
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
              </svg>
              Enviar mensaje
            </button>

            <p class="text-xs text-gray-secondary text-center">
              Al enviar este formulario aceptas nuestra
              <a href="/politica-privacidad" class="text-primary hover:underline">política de privacidad</a>.
            </p>
          </form>
        </div>

        <!-- DATOS DE CONTACTO -->
        <div class="space-y-8">
          <div>
            <h2 class="text-2xl font-bold text-dark mb-6">Información de contacto</h2>

            <div class="space-y-5">
              <!-- Teléfonos -->
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-dark text-sm">Teléfono</p>
                  <a href="tel:+34912507727" class="text-primary hover:underline block">912 50 77 27</a>
                  <a href="tel:+34601335732" class="text-primary hover:underline block text-sm">601 335 732 (cita previa)</a>
                </div>
              </div>

              <!-- Email -->
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-dark text-sm">Email</p>
                  <a href="mailto:clinica@fisioarenal.com" class="text-primary hover:underline">clinica@fisioarenal.com</a>
                </div>
              </div>

              <!-- Dirección -->
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-dark text-sm">Dirección</p>
                  <p class="text-gray-secondary text-sm">C/ Alba de Tormes, 35<br/>Carabanchel, 28025 Madrid</p>
                </div>
              </div>

              <!-- Horario -->
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-dark text-sm">Horario</p>
                  <p class="text-gray-secondary text-sm">Lunes a viernes: 10:00 – 20:00</p>
                  <p class="text-gray-secondary text-sm">Sábados y domingos: Cerrado</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Cómo llegar -->
          <div class="card p-5">
            <h3 class="font-semibold text-dark mb-4 flex items-center gap-2">
              <span>🚇</span> Cómo llegar
            </h3>
            <div class="space-y-3">
              <div>
                <p class="text-sm font-medium text-dark mb-1">Metro</p>
                <div class="flex flex-wrap gap-2">
                  <span class="inline-flex items-center gap-1.5 text-xs bg-blue-100 text-blue-800 px-2.5 py-1 rounded-full font-medium">
                    <span class="w-4 h-4 rounded-full bg-blue-600 inline-block text-white text-center text-[10px] leading-4">5</span>
                    Eugenia de Montijo
                  </span>
                  <span class="inline-flex items-center gap-1.5 text-xs bg-teal-100 text-teal-800 px-2.5 py-1 rounded-full font-medium">
                    <span class="w-4 h-4 rounded-full bg-teal-600 inline-block text-white text-center text-[10px] leading-4">11</span>
                    San Francisco
                  </span>
                </div>
              </div>
              <div>
                <p class="text-sm font-medium text-dark mb-1">Autobuses</p>
                <div class="flex flex-wrap gap-1.5">
                  {['108', '45', '121', '131', '34', '35'].map((bus) => (
                    <span class="text-xs bg-gray-100 text-gray-700 px-2 py-1 rounded font-medium">{bus}</span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MAPA -->
  <section class="pb-16">
    <div class="container-content">
      <div class="rounded-2xl overflow-hidden shadow-md h-80 md:h-96">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3272.9489421540775!2d-3.74713212389701!3d40.37672785807288!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd418829ee907991%3A0x16ab1b4eac60f17d!2sCl%C3%ADnica%20Arenal.%20Fisioterapia%20y%20Osteopat%C3%ADa!5e1!3m2!1ses!2ses!4v1774105031362!5m2!1ses!2ses"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Mapa de Clínica Arenal en Carabanchel, Madrid"
        ></iframe>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const formStatus = document.getElementById('form-status')!;
  const formSuccess = document.getElementById('form-success')!;
  const formError = document.getElementById('form-error')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando...';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      formStatus.classList.remove('hidden');

      if (res.ok) {
        formSuccess.classList.remove('hidden');
        formError.classList.add('hidden');
        form.reset();
      } else {
        throw new Error('Error en el servidor');
      }
    } catch {
      formStatus.classList.remove('hidden');
      formError.classList.remove('hidden');
      formSuccess.classList.add('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = `
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
        </svg>
        Enviar mensaje
      `;
    }
  });
</script>
