---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout
  title="Blog de Fisioterapia | Clínica Arenal Madrid"
  description="Consejos de fisioterapia, ejercicios y salud. Blog de la Clínica Arenal en Carabanchel, Madrid."
  canonical="https://www.fisioarenal.com/blog"
>

  <!-- HERO -->
  <section class="bg-gray-light section-padding border-b border-gray-200/60">
    <div class="container-content">
      <div class="max-w-2xl">
        <span class="text-primary font-medium text-sm uppercase tracking-widest">Consejos y salud</span>
        <h1 class="text-4xl md:text-5xl font-serif font-bold text-dark mt-3 mb-4 leading-tight">
          Blog de Fisioterapia
        </h1>
        <p class="text-gray-secondary text-lg leading-relaxed">
          Artículos, consejos y recursos sobre fisioterapia, ejercicio y bienestar
          escritos por nuestro equipo de profesionales.
        </p>
      </div>
    </div>
  </section>

  <!-- ARTÍCULOS -->
  <section class="section-padding">
    <div class="container-content">
      {sortedPosts.length === 0 ? (
        <div class="text-center py-20">
          <div class="w-16 h-16 bg-primary/8 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
            </svg>
          </div>
          <h2 class="text-2xl font-serif font-bold text-dark mb-3">Próximamente</h2>
          <p class="text-gray-secondary max-w-md mx-auto mb-8">
            Estamos preparando artículos con consejos de fisioterapia, ejercicios y
            todo lo que necesitas saber para cuidar tu salud.
          </p>
          <a href="/contacto" class="btn-primary">Contactar con nosotros</a>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {sortedPosts.map((post) => (
            <a
              href={`/blog/${post.slug}`}
              class="card group overflow-hidden hover:-translate-y-1 transition-transform duration-200"
            >
              {post.data.image && (
                <div class="aspect-video overflow-hidden bg-gray-100">
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    width="400"
                    height="225"
                  />
                </div>
              )}
              <div class="p-6">
                <div class="flex items-center gap-2 mb-3">
                  {post.data.category && (
                    <span class="text-xs bg-primary/10 text-primary font-medium px-2.5 py-1 rounded-full">
                      {post.data.category}
                    </span>
                  )}
                  <time class="text-xs text-gray-secondary" datetime={post.data.date}>
                    {new Date(post.data.date).toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' })}
                  </time>
                </div>
                <h2 class="text-lg font-semibold text-dark mb-2 group-hover:text-primary transition-colors leading-snug">
                  {post.data.title}
                </h2>
                <p class="text-gray-secondary text-sm leading-relaxed line-clamp-3">
                  {post.data.excerpt}
                </p>
                <span class="mt-4 inline-flex items-center gap-1 text-primary text-sm font-medium">
                  Leer artículo
                  <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

</BaseLayout>
