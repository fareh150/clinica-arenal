---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceIcon from '../components/ServiceIcon.astro';
import { services } from '../data/services';
import { testimonials } from '../data/testimonials';

const featuredServices = services.slice(0, 6);
const featuredTestimonials = testimonials.filter((t) => t.featured);
---

<BaseLayout
  title="Clínica Arenal | Fisioterapia y Osteopatía en Carabanchel, Madrid"
  description="Clínica de fisioterapia, osteopatía y pilates en Carabanchel, Madrid. Más de 14 años de experiencia. 5.0★ en Google. Pide cita: 912 50 77 27."
>

  <!-- HERO -->
  <section class="relative min-h-[90vh] flex items-center overflow-hidden bg-dark">
    <div class="absolute inset-0">
      <img
        src="/images/header-clinica-arenal.jpg"
        alt="Clínica Arenal — Fisioterapia y Osteopatía en Carabanchel, Madrid"
        class="w-full h-full object-cover opacity-25"
        width="1920"
        height="1080"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-dark/95 via-dark/75 to-dark/20"></div>
    </div>

    <div class="relative container-content py-20">
      <div class="max-w-2xl">
        <!-- Rating — sin glassmorphism genérico -->
        <div class="inline-flex items-center gap-3 mb-8">
          <div class="flex gap-0.5">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <span class="text-white/70 text-sm">5.0 · 31 reseñas en Google</span>
        </div>

        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-serif font-bold text-white leading-[1.1] mb-6">
          Fisioterapia y<br/>Osteopatía en<br/><span class="text-primary-light">Carabanchel</span>
        </h1>

        <p class="text-lg sm:text-xl text-white/75 mb-10 leading-relaxed max-w-lg">
          Más de 14 años cuidando tu salud con trato cercano y profesional.
          Fisioterapia, osteopatía, pilates y más en el corazón de Madrid.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contacto" class="btn-primary text-base px-8 py-4">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            Pide tu cita
          </a>
          <a href="tel:+34912507727" class="btn-white text-base px-8 py-4">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            912 50 77 27
          </a>
        </div>

        <!-- Datos rápidos — sin tarjetas genéricas, texto limpio -->
        <div class="flex flex-wrap gap-8 mt-12 pt-10 border-t border-white/15">
          <div>
            <span class="block text-3xl font-serif font-bold text-primary-light">+14</span>
            <span class="text-xs text-white/50 uppercase tracking-widest mt-1 block">años de experiencia</span>
          </div>
          <div>
            <span class="block text-3xl font-serif font-bold text-primary-light">5.0★</span>
            <span class="text-xs text-white/50 uppercase tracking-widest mt-1 block">en Google</span>
          </div>
          <div>
            <span class="block text-3xl font-serif font-bold text-primary-light">12</span>
            <span class="text-xs text-white/50 uppercase tracking-widest mt-1 block">especialidades</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICIOS DESTACADOS -->
  <section class="section-padding bg-gray-light">
    <div class="container-content">
      <div class="text-center mb-12">
        <span class="text-primary font-medium text-sm uppercase tracking-widest">Especialidades</span>
        <h2 class="section-title mt-2">Nuestros Tratamientos</h2>
        <p class="section-subtitle mx-auto">
          Tratamientos personalizados para cada paciente. Desde fisioterapia deportiva hasta pilates terapéutico.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredServices.map((service) => (
          <a
            href={`/tratamientos/${service.slug}`}
            class="card group p-6 flex flex-col hover:-translate-y-1 transition-transform duration-200"
          >
            <div class="w-11 h-11 bg-primary/8 rounded-lg flex items-center justify-center mb-4 text-primary group-hover:bg-primary group-hover:text-white transition-colors duration-200">
              <ServiceIcon slug={service.slug} class="w-5 h-5" />
            </div>
            <h3 class="text-base font-semibold text-dark mb-2 group-hover:text-primary transition-colors">
              {service.title}
            </h3>
            <p class="text-gray-secondary text-sm leading-relaxed flex-1">
              {service.shortDescription}
            </p>
            <span class="mt-4 text-primary text-sm font-medium inline-flex items-center gap-1">
              Saber más
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/tratamientos" class="btn-secondary">
          Ver todos los tratamientos
        </a>
      </div>
    </div>
  </section>

  <!-- SOBRE NOSOTROS — Silvia en primer plano -->
  <section class="section-padding">
    <div class="container-content">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="text-primary font-medium text-sm uppercase tracking-widest">Quiénes somos</span>
          <h2 class="section-title mt-2">
            Fisioterapeutas con vocación y experiencia
          </h2>
          <p class="text-gray-secondary leading-relaxed mb-6">
            En la Clínica Arenal somos un equipo de fisioterapeutas y osteópatas con amplia experiencia
            que, con un trato cercano y profesional, ponemos nuestros servicios a tu disposición para
            tratar tus dolencias, mejorar tu calidad de vida y conseguir una mejora de tu salud y bienestar.
          </p>
          <p class="text-gray-secondary leading-relaxed mb-8">
            Dirigida por Silvia Arenal Antón, fisioterapeuta y osteópata con más de 14 años de experiencia
            y colaboradora de la Federación Madrileña de Balonmano.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/quienes-somos" class="btn-primary">
              Conoce nuestro equipo
            </a>
            <a href="/instalaciones" class="btn-secondary">
              Ver instalaciones
            </a>
          </div>
        </div>

        <div class="relative">
          <img
            src="/images/team/silvia-arenal-fisioterapeuta.jpg"
            alt="Silvia Arenal Antón — Directora y fisioterapeuta de Clínica Arenal"
            class="rounded-2xl w-full max-w-sm mx-auto lg:mx-0 lg:ml-auto object-cover shadow-lg"
            width="480"
            height="560"
          />
          <div class="absolute -bottom-4 -left-4 lg:left-auto lg:-right-4 bg-primary text-white rounded-xl p-4 shadow-lg hidden md:block">
            <span class="block text-2xl font-serif font-bold">14+</span>
            <span class="text-xs text-white/80 uppercase tracking-wide">años de experiencia</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FILOSOFÍA — reemplaza el genérico "¿Cómo trabajamos?" -->
  <section class="section-padding bg-gray-light">
    <div class="container-content">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="relative order-2 lg:order-1">
          <img
            src="/images/fisioterapia-home.jpg"
            alt="Tratamiento personalizado en Clínica Arenal"
            class="rounded-2xl w-full object-cover shadow-lg"
            width="600"
            height="450"
          />
          <!-- Detalle decorativo -->
          <div class="absolute -top-4 -left-4 w-20 h-20 bg-primary/10 rounded-2xl -z-10 hidden lg:block"></div>
        </div>

        <div class="order-1 lg:order-2">
          <span class="text-primary font-medium text-sm uppercase tracking-widest">Nuestra filosofía</span>
          <h2 class="section-title mt-2 italic">
            "Miremos al cuerpo como un todo, en todo su conjunto"
          </h2>
          <p class="text-gray-secondary leading-relaxed mb-6">
            En Clínica Arenal no tratamos síntomas de forma aislada. Entendemos el cuerpo como un sistema
            integrado donde cada parte influye en el resto. Por eso cada tratamiento empieza con una
            valoración completa y termina cuando tú estás bien, no cuando acaba la sesión.
          </p>
          <div class="space-y-4">
            {[
              { title: 'Valoración completa', desc: 'Anamnesis, exploración física y diagnóstico fisioterapéutico desde el primer día.' },
              { title: 'Plan personalizado', desc: 'Adaptado a tu diagnóstico, tu ritmo y tu vida, no a un protocolo estándar.' },
              { title: 'Acompañamiento real', desc: 'Te seguimos hasta tu total recuperación, no solo mientras hay sesiones.' },
            ].map((item) => (
              <div class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-primary/15 flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-3 h-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <div>
                  <span class="font-semibold text-dark text-sm">{item.title}</span>
                  <span class="text-gray-secondary text-sm"> — {item.desc}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIOS -->
  <section class="section-padding">
    <div class="container-content">
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 mb-4">
          <div class="flex gap-0.5">
            {[1,2,3,4,5].map(() => (
              <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <span class="text-gray-secondary text-sm font-medium">5.0 · 31 reseñas en Google</span>
        </div>
        <h2 class="section-title">Lo que dicen nuestros pacientes</h2>
        <p class="section-subtitle mx-auto">
          Reseñas reales de pacientes que han confiado en nuestro equipo.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {featuredTestimonials.map((testimonial) => (
          <div class="card p-7">
            <div class="flex gap-0.5 mb-4" aria-label={`${testimonial.rating} estrellas sobre 5`}>
              {Array.from({ length: testimonial.rating }).map(() => (
                <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <!-- Comillas decorativas en serif -->
            <p class="text-[1.35rem] font-serif text-primary/30 leading-none mb-1 select-none">"</p>
            <blockquote class="text-gray-text leading-relaxed mb-5 text-sm">
              {testimonial.text}
            </blockquote>

            <div class="flex items-center justify-between pt-4 border-t border-gray-100">
              <cite class="not-italic font-semibold text-dark text-sm">{testimonial.name}</cite>
              <span class="text-xs text-gray-secondary">Reseña de Google</span>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-8">
        <a
          href="https://www.google.com/maps/search/Cl%C3%ADnica+Arenal+Madrid"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary inline-flex items-center gap-2"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
          </svg>
          Ver todas las reseñas en Google
        </a>
      </div>
    </div>
  </section>

  <!-- CTA FINAL — personal, no el bloque verde genérico -->
  <section class="section-padding bg-dark">
    <div class="container-content">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-white mb-4">
            ¿Tienes alguna dolencia?<br/>Te ayudamos.
          </h2>
          <p class="text-white/65 text-lg mb-3 leading-relaxed">
            Atendemos en Carabanchel, Madrid, de lunes a viernes.
            Pide tu cita por teléfono, WhatsApp o formulario.
          </p>
          <p class="text-white/40 text-sm italic mb-8">
            "Definitivamente no hay punto de comparación con Silvia... te deja como nuevo."
            <span class="not-italic font-medium text-white/50"> — Armando P., paciente</span>
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/contacto" class="btn-primary text-base px-8 py-4">
              Pedir cita online
            </a>
            <a href="tel:+34912507727" class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/30 text-white font-semibold rounded-lg hover:border-white/60 transition-colors text-base">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              912 50 77 27
            </a>
          </div>
        </div>

        <!-- Info de contacto rápida -->
        <div class="space-y-5 lg:pl-8 lg:border-l lg:border-white/10">
          <div class="flex items-start gap-4">
            <div class="w-9 h-9 bg-primary/20 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-primary-light" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <p class="text-white/90 text-sm font-medium">C/ Alba de Tormes, 35</p>
              <p class="text-white/50 text-sm">Carabanchel, 28025 Madrid</p>
              <p class="text-white/40 text-xs mt-1">Metro San Francisco (L11) · Eugenia de Montijo (L5)</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-9 h-9 bg-primary/20 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-primary-light" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <p class="text-white/90 text-sm font-medium">Lunes a Viernes</p>
              <p class="text-white/50 text-sm">10:00 – 20:00</p>
              <p class="text-white/40 text-xs mt-1">Sábados y domingos cerrado</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-9 h-9 bg-primary/20 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-primary-light" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div>
              <a href="https://wa.me/34601335732" target="_blank" rel="noopener noreferrer" class="text-white/90 hover:text-white text-sm font-medium transition-colors">
                WhatsApp — 601 335 732
              </a>
              <p class="text-white/40 text-xs mt-1">Respuesta rápida para cita previa</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
