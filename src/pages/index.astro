---
import BaseLayout from '../layouts/BaseLayout.astro';
import { services } from '../data/services';
import { testimonials } from '../data/testimonials';

const featuredServices = services.slice(0, 6);
const featuredTestimonials = testimonials.filter((t) => t.featured);
---

<BaseLayout
  title="Clínica Arenal | Fisioterapia y Osteopatía en Carabanchel, Madrid"
  description="Clínica de fisioterapia, osteopatía y pilates en Carabanchel, Madrid. Más de 14 años de experiencia. 5.0★ en Google. Pide cita: 912 50 77 27."
>

  <!-- HERO -->
  <section class="relative min-h-[90vh] flex items-center overflow-hidden bg-dark">
    <div class="absolute inset-0">
      <img
        src="/images/header-clinica-arenal.jpg"
        alt="Clínica Arenal — Fisioterapia y Osteopatía en Carabanchel, Madrid"
        class="w-full h-full object-cover opacity-30"
        width="1920"
        height="1080"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-dark/90 via-dark/70 to-dark/30"></div>
    </div>

    <div class="relative container-content py-20">
      <div class="max-w-2xl">
        <!-- Badge de rating -->
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-2 mb-6">
          <span class="text-yellow-400 font-bold text-sm">★★★★★ 5.0</span>
          <span class="text-white/80 text-sm">— 31 reseñas en Google</span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
          Fisioterapia y Osteopatía en <span class="text-primary-light">Carabanchel</span>
        </h1>

        <p class="text-lg sm:text-xl text-white/80 mb-8 leading-relaxed">
          Más de 14 años cuidando tu salud con trato cercano y profesional.
          Fisioterapia, osteopatía, pilates y más en el corazón de Madrid.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contacto" class="btn-primary text-base px-8 py-4">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            Pide tu cita
          </a>
          <a href="tel:+34912507727" class="btn-white text-base px-8 py-4">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            912 50 77 27
          </a>
        </div>

        <!-- Datos rápidos -->
        <div class="flex flex-wrap gap-6 mt-10">
          <div class="text-white/90">
            <span class="block text-2xl font-bold text-primary-light">+14</span>
            <span class="text-sm text-white/60">años de experiencia</span>
          </div>
          <div class="text-white/90">
            <span class="block text-2xl font-bold text-primary-light">5.0★</span>
            <span class="text-sm text-white/60">en Google</span>
          </div>
          <div class="text-white/90">
            <span class="block text-2xl font-bold text-primary-light">12</span>
            <span class="text-sm text-white/60">especialidades</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICIOS DESTACADOS -->
  <section class="section-padding bg-gray-light">
    <div class="container-content">
      <div class="text-center mb-12">
        <h2 class="section-title">Nuestros Tratamientos</h2>
        <p class="section-subtitle mx-auto">
          Tratamientos personalizados para cada paciente. Desde fisioterapia deportiva hasta pilates terapéutico.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredServices.map((service) => (
          <a
            href={`/tratamientos/${service.slug}`}
            class="card group p-6 flex flex-col hover:-translate-y-1 transition-transform duration-200"
          >
            <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-4 text-2xl group-hover:bg-primary/20 transition-colors">
              {service.icon}
            </div>
            <h3 class="text-lg font-semibold text-dark mb-2 group-hover:text-primary transition-colors">
              {service.title}
            </h3>
            <p class="text-gray-secondary text-sm leading-relaxed flex-1">
              {service.shortDescription}
            </p>
            <span class="mt-4 text-primary text-sm font-medium inline-flex items-center gap-1">
              Saber más
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/tratamientos" class="btn-secondary">
          Ver todos los tratamientos
        </a>
      </div>
    </div>
  </section>

  <!-- SOBRE NOSOTROS -->
  <section class="section-padding">
    <div class="container-content">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="text-primary font-semibold text-sm uppercase tracking-wider">Quiénes somos</span>
          <h2 class="section-title mt-2">
            Fisioterapeutas con vocación y experiencia
          </h2>
          <p class="text-gray-secondary leading-relaxed mb-6">
            En la Clínica Arenal somos un equipo de fisioterapeutas y osteópatas con amplia experiencia
            que, con un trato cercano y profesional, ponemos nuestros servicios a tu disposición para
            tratar tus dolencias, mejorar tu calidad de vida y conseguir una mejora de tu salud y bienestar.
          </p>
          <p class="text-gray-secondary leading-relaxed mb-8">
            Dirigida por Silvia Arenal Antón, fisioterapeuta y osteópata con más de 14 años de experiencia
            y colaboradora de la Federación Madrileña de Balonmano.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/quienes-somos" class="btn-primary">
              Conoce nuestro equipo
            </a>
            <a href="/instalaciones" class="btn-secondary">
              Ver instalaciones
            </a>
          </div>
        </div>

        <div class="relative">
          <img
            src="/images/fisioterapia-home.jpg"
            alt="Fisioterapeuta de Clínica Arenal realizando un tratamiento"
            class="rounded-2xl w-full object-cover shadow-lg"
            width="600"
            height="450"
          />
          <!-- Badge flotante -->
          <div class="absolute -bottom-4 -left-4 bg-primary text-white rounded-xl p-4 shadow-lg">
            <span class="block text-2xl font-bold">14+</span>
            <span class="text-sm text-white/80">años de experiencia</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESO DE TRATAMIENTO -->
  <section class="section-padding bg-gray-light">
    <div class="container-content">
      <div class="text-center mb-12">
        <h2 class="section-title">¿Cómo trabajamos?</h2>
        <p class="section-subtitle mx-auto">
          Un proceso sencillo y personalizado para conseguir los mejores resultados para tu salud.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            step: '01',
            title: 'Consulta inicial',
            description: 'Realizamos una valoración completa de tu situación: anamnesis, exploración física y diagnóstico fisioterapéutico.',
            icon: '🩺',
          },
          {
            step: '02',
            title: 'Plan de tratamiento',
            description: 'Diseñamos un programa personalizado adaptado a tu diagnóstico, objetivos y ritmo de vida.',
            icon: '📋',
          },
          {
            step: '03',
            title: 'Recuperación',
            description: 'Aplicamos las técnicas más efectivas y te acompañamos hasta tu total recuperación y bienestar.',
            icon: '💪',
          },
        ].map((item) => (
          <div class="relative text-center">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-primary text-white rounded-2xl text-2xl mb-4">
              {item.icon}
            </div>
            <div class="absolute top-4 left-1/2 -translate-x-1/2 -translate-y-1 text-xs font-bold text-primary/30 text-6xl select-none pointer-events-none">
              {item.step}
            </div>
            <h3 class="text-xl font-semibold text-dark mb-3">{item.title}</h3>
            <p class="text-gray-secondary text-sm leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIOS -->
  <section class="section-padding">
    <div class="container-content">
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 bg-yellow-50 border border-yellow-200 rounded-full px-4 py-2 mb-4">
          <span class="text-yellow-500 font-bold">★★★★★ 5.0</span>
          <span class="text-gray-secondary text-sm">— 31 reseñas en Google</span>
        </div>
        <h2 class="section-title">Lo que dicen nuestros pacientes</h2>
        <p class="section-subtitle mx-auto">
          Reseñas reales de pacientes que han confiado en nuestro equipo.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {featuredTestimonials.map((testimonial) => (
          <div class="card p-6">
            <!-- Stars -->
            <div class="flex gap-0.5 mb-3" aria-label={`${testimonial.rating} estrellas sobre 5`}>
              {Array.from({ length: testimonial.rating }).map(() => (
                <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <blockquote class="text-gray-text leading-relaxed mb-4 italic">
              "{testimonial.text}"
            </blockquote>

            <div class="flex items-center justify-between">
              <div>
                <cite class="not-italic font-semibold text-dark text-sm">{testimonial.name}</cite>
                <p class="text-gray-secondary text-xs">{testimonial.date}</p>
              </div>
              <span class="text-xs text-gray-secondary bg-gray-50 px-2 py-1 rounded-full border">
                Reseña de Google
              </span>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-8">
        <a
          href="https://www.google.com/maps/search/Cl%C3%ADnica+Arenal+Madrid"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary inline-flex items-center gap-2"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
          </svg>
          Ver todas las reseñas en Google
        </a>
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="section-padding bg-primary">
    <div class="container-content text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        ¿Tienes alguna dolencia? Te ayudamos
      </h2>
      <p class="text-white/80 text-lg mb-8 max-w-2xl mx-auto">
        Pide tu cita ahora y empieza tu camino hacia el bienestar. Atendemos en
        Carabanchel, Madrid, de lunes a viernes.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contacto" class="btn-white text-base px-8 py-4">
          Pedir cita online
        </a>
        <a href="tel:+34912507727" class="inline-flex items-center justify-center gap-2 px-8 py-4 border-2 border-white text-white font-semibold rounded-lg hover:bg-white hover:text-primary transition-colors text-base">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          912 50 77 27
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
