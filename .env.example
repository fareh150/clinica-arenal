# ─── RESEND (formulario de contacto) ───────────────────────────────
# Obtén tu API key en https://resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# El email donde quieres recibir los mensajes del formulario
# En DEV: debe ser el mismo email con el que te registraste en Resend
# En PROD (con dominio verificado): puede ser cualquier email, ej. clinica@fisioarenal.com
RESEND_TO_EMAIL=tu@email.com
